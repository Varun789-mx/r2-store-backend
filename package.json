{
  "name": "driveapp",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
   "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "migrate:dev": "bun prisma migrate dev",
    "migrate:prod": "bun prisma migrate deploy",
    "start": "bun run dist/index.js",
    "start:prod": "bun prisma migrate deploy && ls"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "6.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@auth/express": "^0.12.1",
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/lib-storage": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "6.5.0",
    "@prisma/extension-accelerate": "2.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "nanoid": "^5.1.6"
  }
}